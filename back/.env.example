# Groq AI API Key
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# JWT Secret Key (generate a strong random string)
JWT_SECRET_KEY=your_jwt_secret_key_here_make_it_very_long_and_random

# MongoDB Connection String
# Format: mongodb+srv://username:password@cluster.mongodb.net/database_name?retryWrites=true&w=majority
MONGO_URI=your_mongodb_connection_string_here

# Environment (development or production)
ENVIRONMENT=development
FLASK_ENV=development

# Frontend URL (for production deployment)
FRONTEND_URL=https://your-frontend-url.com
